# Neon Postgres (server-side only)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Coda API (server-side only, used for portfolio companies until migrated)
CODA_PORTFOLIO_COMPANIES=your_token_here

# PostHog analytics (client-side, safe to expose)
POSTHOG_TOKEN=your_token_here
POSTHOG_HOST=https://eu.i.posthog.com
